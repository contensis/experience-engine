  "version": "1.0.0-beta.0",
  "description": "Create personalized experiences with React and Contensis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contensis/experience-engine.git"
  },
  "homepage": "https://github.com/contensis/experience-engine/tree/main/packages/react#readme",
  "main": "dist/experience-engine-react.js",
  "module": "dist/experience-engine-react.mjs",
