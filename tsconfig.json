{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    // "incremental": true,
    "target": "es2019",
    "module": "ESNext",
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    // "composite": true,
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
