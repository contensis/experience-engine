{
  "name": "contensis-personalization",
  "version": "0.0.0",
  "description": "Create a personalized experience with Contensis",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "npm -w react-router-app run dev",
    "test": "cross-env START_SERVER_AND_TEST_INSECURE=1 start-server-and-test start https://localhost:5173 e2e",
    "test:open": "cross-env START_SERVER_AND_TEST_INSECURE=1 start-server-and-test start https://localhost:5173 cy:open",
    "cy:open": "cypress open",
    "e2e": "npm run e2e:chrome && npm run e2e:edge && npm run e2e:firefox",
    "e2e:chrome": "cypress run --browser chrome",
    "e2e:edge": "cypress run --browser edge",
    "e2e:firefox": "cypress run --browser firefox"
  },
  "author": "Zengenti",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@microsoft/api-extractor": "^7.47.11",
    "@tsconfig/recommended": "^1.0.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "browserslist-to-esbuild": "^2.1.1",
    "cross-env": "^7.0.3",
    "cypress": "^14.2.0",
    "cypress-wait-until": "^3.0.2",
    "eslint": "^9.15.0",
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-cypress": "^4.1.0",
    "eslint-plugin-mocha": "^10.5.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "start-server-and-test": "^2.0.8",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
